{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m pytest *)",
      "Bash(python -m ruff check *)",
      "Bash(python -m ruff format --check *)",
      "Bash(python -m mypy *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(aegis validate *)",
      "Bash(aegis doctor)",
      "Bash(aegis tools *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(~/.aegis/**)",
      "Edit(./runs/**)",
      "Write(./runs/**)",
      "Bash(aegis scan *)",
      "Bash(python -m aegis_bounty scan *)",
      "Bash(python -m aegis_bounty scan-url *)",
      "Bash(subfinder *)",
      "Bash(amass *)",
      "Bash(nuclei *)",
      "Bash(dirsearch *)",
      "Bash(reconftw*)",
      "Bash(osmedeus *)",
      "Bash(apkleaks *)",
      "Bash(scan4all *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)"
    ]
  }
}
